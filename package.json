{
  "name": "adc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "// Déploiement standard": "",
    "deploy": "npm run build && npm run start",
    "prepare-export": "node scripts/prepare-export.mjs",
    "export": "next build && next export",
    "deploy-static": "npm run prepare-export && echo 'Votre site est prêt à être déployé. Uploadez le contenu du dossier \"out\" sur votre hébergeur.'",
    "// Déploiement Hostinger": "",
    "deploy-hostinger": "bash scripts/hostinger-deploy.sh",
    "deploy-production": "bash scripts/deploy-production.sh",
    "deploy-optimized": "bash scripts/deploy-optimized.sh",
    "// Optimisation des images": "",
    "optimize-images": "bash scripts/optimize-images.sh",
    "optimize-large-images": "bash scripts/optimize-large-images.sh",
    "create-webp": "bash scripts/create-webp-versions.sh",
    "convert-all-to-webp": "bash scripts/convert-all-to-webp.sh",
    "// Commandes de nettoyage": "",
    "clean-output": "bash scripts/clean-output.sh",
    "cleanup-cache": "bash scripts/cleanup-cache.sh",
    "cleanup-unused-images": "bash scripts/cleanup-unused-images.sh",
    "cleanup-unused-images-delete": "bash scripts/cleanup-unused-images.sh --delete",
    "fix-directory-names": "bash scripts/fix-directory-names.sh",
    "// Commandes utilitaires": "",
    "generate-image-manifest": "node scripts/generate-image-manifest.mjs",
    "prepare-images": "npm run optimize-images && npm run generate-image-manifest",
    "split-img-packages": "bash scripts/split-img-for-upload.sh",
    "split-images": "bash scripts/split-img-for-upload.sh",
    "verify-images": "node scripts/verify-images.mjs",
    "fix-images": "node scripts/fix-images-paths.mjs",
    "fix-missing-images": "bash scripts/fix-missing-images.sh",
    "// Commandes combinées": "",
    "prepare-upload": "npm run deploy-hostinger && npm run split-img-packages",
    "deploy-safe": "npm run deploy-hostinger && npm run verify-images",
    "deploy-hostinger-optimized": "npm run deploy-hostinger && npm run optimize-large-images",
    "fix-and-verify": "npm run fix-images && npm run verify-images",
    "deploy-complete": "npm run deploy-hostinger && npm run optimize-large-images && npm run verify-images",
    "convert-and-deploy": "npm run deploy-hostinger && npm run convert-all-to-webp",
    "fix-deploy": "bash scripts/fix-komate-image.sh && npm run deploy-production"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-navigation-menu": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@tsparticles/engine": "^3.7.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.471.1",
    "mini-svg-data-uri": "^1.4.4",
    "next": "14.2.16",
    "next-intl": "^4.9.1",
    "posthog-js": "^1.372.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.50.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tsparticles": "^3.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "autoprefixer": "^10.4.20",
    "chalk": "^5.4.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.16",
    "glob": "^11.0.1",
    "image-webpack-loader": "^8.1.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-optipng": "^8.0.0",
    "imagemin-webp": "^7.0.0",
    "next-optimized-images": "^2.6.2",
    "postcss": "^8.5.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
